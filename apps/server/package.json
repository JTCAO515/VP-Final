{
  "name": "@visepanda/app-server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./db": {
      "types": "./src/db/client.ts",
      "default": "./dist/db/client.js"
    },
    "./db-ops-authorization": {
      "types": "./src/db/opsAuthorizationService.ts",
      "default": "./dist/db/opsAuthorizationService.js"
    },
    "./ops-authorization": {
      "types": "./src/modules/opsAuthorization/service.ts",
      "default": "./dist/modules/opsAuthorization/service.js"
    },
    "./runtime": {
      "types": "./src/runtime/runtimeMode.ts",
      "default": "./dist/runtime/runtimeMode.js"
    },
    "./router": {
      "types": "./src/router.ts",
      "default": "./dist/router.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "prettier --check src"
  },
  "dependencies": {
    "@trpc/server": "^11.18.0",
    "@upstash/qstash": "2.11.2",
    "@visepanda/ai": "workspace:*",
    "@visepanda/domain": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
